# Zugangsdaten fuer die FRITZ!Box (Home-Netz-Login: Benutzername + Passwort).
# Diese Datei nach .env kopieren und Werte eintragen. .env wird ignoriert.
FRITZ_USERNAME=
FRITZ_PASSWORD=
# Optional:
# FRITZ_HOST=https://fritz.box
# POLL_INTERVAL=30s
# DASHBOARD_ADDR=:8080

# Syslog / Eventlog (Postgres fuer Speicherung, Syslog fuer Versand)
# DATABASE_URL=postgres://user:pass@host/db?sslmode=disable
# SYSLOG_HOST=10.0.0.5
# SYSLOG_PORT=514
# SYSLOG_PROTOCOL=udp